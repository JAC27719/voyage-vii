diff --git a/src/stream.zig b/src/stream.zig
index dbf4c77..a933dfe 100644
--- a/src/stream.zig
+++ b/src/stream.zig
@@ -1,0 +2 @@ const std = @import("std");
+const builtin = @import("builtin");
@@ -6,0 +8 @@ const posix = std.posix;
+const windows = std.os.windows;
@@ -13,0 +16 @@ pub const Stream = if (lib.has_openssl) TLSStream else PlainStream;
+const WINDOWS_CONNECT_TIMEOUT_MS = 5_000;
@@ -143,0 +147,3 @@ const PlainStream = struct {
+            if (comptime builtin.os.tag == .windows) {
+                break :blk (try tcpConnectToHostWindows(allocator, host, port, WINDOWS_CONNECT_TIMEOUT_MS)).handle;
+            }
@@ -169,0 +176,92 @@ const PlainStream = struct {
+fn tcpConnectToHostWindows(
+    allocator: Allocator,
+    name: []const u8,
+    port: u16,
+    timeout_ms: i32,
+) !std.net.Stream {
+    const list = try std.net.getAddressList(allocator, name, port);
+    defer list.deinit();
+
+    if (list.addrs.len == 0) return error.UnknownHostName;
+
+    for (list.addrs) |addr| {
+        return tcpConnectToAddressWindows(addr, timeout_ms) catch |err| switch (err) {
+            error.ConnectionRefused => continue,
+            else => return err,
+        };
+    }
+    return error.ConnectionRefused;
+}
+
+fn tcpConnectToAddressWindows(address: std.net.Address, timeout_ms: i32) !std.net.Stream {
+    const sock_flags = posix.SOCK.STREAM | posix.SOCK.NONBLOCK;
+    const socket = try posix.socket(address.any.family, sock_flags, posix.IPPROTO.TCP);
+    errdefer posix.close(socket);
+
+    posix.connect(socket, &address.any, address.getOsSockLen()) catch |err| switch (err) {
+        error.WouldBlock => {},
+        else => return err,
+    };
+
+    var poll_fds = [_]posix.pollfd{.{
+        .fd = socket,
+        .events = posix.POLL.OUT,
+        .revents = 0,
+    }};
+
+    const ready = try posix.poll(&poll_fds, timeout_ms);
+    if (ready == 0) {
+        return error.ConnectionTimedOut;
+    }
+
+    try socketConnectErrorWindows(socket);
+    try setSocketBlockingWindows(socket);
+
+    return .{ .handle = socket };
+}
+
+fn socketConnectErrorWindows(socket: posix.socket_t) !void {
+    var err_code: c_int = 0;
+    var err_len: i32 = @sizeOf(c_int);
+    const rc = windows.ws2_32.getsockopt(
+        socket,
+        posix.SOL.SOCKET,
+        @intCast(posix.SO.ERROR),
+        @ptrCast(&err_code),
+        &err_len,
+    );
+    if (rc == windows.ws2_32.SOCKET_ERROR) {
+        return windows.unexpectedWSAError(windows.ws2_32.WSAGetLastError());
+    }
+    if (err_code == 0) return;
+
+    switch (@as(windows.ws2_32.WinsockError, @enumFromInt(@as(u16, @intCast(err_code))))) {
+        .WSAEACCES => return error.AccessDenied,
+        .WSAEADDRINUSE => return error.AddressInUse,
+        .WSAEADDRNOTAVAIL => return error.AddressNotAvailable,
+        .WSAEAFNOSUPPORT => return error.AddressFamilyNotSupported,
+        .WSAECONNREFUSED => return error.ConnectionRefused,
+        .WSAECONNRESET => return error.ConnectionResetByPeer,
+        .WSAETIMEDOUT => return error.ConnectionTimedOut,
+        .WSAEHOSTUNREACH,
+        .WSAENETUNREACH,
+        => return error.NetworkUnreachable,
+        .WSAENOBUFS => return error.SystemResources,
+        .WSAEWOULDBLOCK,
+        .WSAEINPROGRESS,
+        .WSAEALREADY,
+        => return error.ConnectionPending,
+        .WSAEISCONN => return,
+        else => |err| return windows.unexpectedWSAError(err),
+    }
+}
+
+fn setSocketBlockingWindows(socket: posix.socket_t) !void {
+    var mode: c_ulong = 0;
+    if (windows.ws2_32.ioctlsocket(socket, windows.ws2_32.FIONBIO, &mode) == windows.ws2_32.SOCKET_ERROR) {
+        switch (windows.ws2_32.WSAGetLastError()) {
+            else => |err| return windows.unexpectedWSAError(err),
+        }
+    }
+}
+
