{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voyage-vii.local/contracts/status.schema.json",
  "type": "object",
  "required": ["schemaVersion", "requestId", "overallState", "components"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "requestId": { "type": "string", "minLength": 1 },
    "overallState": { "enum": ["starting", "ready", "degraded", "stopping"] },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "displayName", "version", "state", "lastCheckedAt", "attemptCount", "error"],
        "additionalProperties": false,
        "properties": {
          "id": { "enum": ["postgresql", "tigerbeetle"] },
          "displayName": { "type": "string" },
          "version": { "type": "string" },
          "state": { "enum": ["starting", "healthy", "retrying", "unhealthy", "stopping", "stopped"] },
          "lastCheckedAt": { "type": ["string", "null"], "format": "date-time" },
          "attemptCount": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
          "error": {
            "type": ["object", "null"],
            "required": ["code", "message"],
            "additionalProperties": false,
            "properties": {
              "code": {
                "enum": [
                  "invalid_request",
                  "body_too_large",
                  "unauthorized",
                  "forbidden",
                  "origin_not_allowed",
                  "method_not_allowed",
                  "not_found",
                  "component_not_found",
                  "retry_not_allowed",
                  "service_unavailable",
                  "shutting_down",
                  "internal_error",
                  "postgres_unavailable",
                  "postgres_authentication_failed",
                  "postgres_timeout",
                  "tigerbeetle_unavailable",
                  "tigerbeetle_timeout",
                  "native_shutdown_timeout",
                  "runtime_asset_missing",
                  "runtime_asset_invalid",
                  "data_root_locked"
                ]
              },
              "message": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
