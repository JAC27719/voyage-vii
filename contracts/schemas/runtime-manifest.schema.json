{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voyage-vii.local/contracts/runtime-manifest.schema.json",
  "type": "object",
  "required": ["schemaVersion", "productVersion", "target", "components"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "productVersion": { "const": "0.1.0" },
    "target": { "const": "x86_64-pc-windows-msvc" },
    "components": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["id", "version", "path", "sha256", "licensePath", "source"],
        "additionalProperties": false,
        "properties": {
          "id": { "enum": ["api", "postgresql", "tigerbeetle"] },
          "version": { "type": "string" },
          "path": { "$ref": "#/$defs/relativePosixPath" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "licensePath": {
            "anyOf": [
              { "type": "null" },
              { "$ref": "#/$defs/relativePosixPath" }
            ]
          },
          "source": {
            "type": "object",
            "required": ["kind", "url", "revision"],
            "additionalProperties": false,
            "properties": {
              "kind": { "enum": ["official-source", "official-release", "first-party-build"] },
              "url": { "type": ["string", "null"], "format": "uri" },
              "revision": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "relativePosixPath": {
      "type": "string",
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\\\)(?!.*(^|/)\\.\\.($|/))(?!.*(^|/)(Users|AppData|secret|secrets|cache|\\.zig-cache)($|/))[A-Za-z0-9._-]+(?:/[A-Za-z0-9._-]+)*$"
    }
  }
}
