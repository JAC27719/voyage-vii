{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voyage-vii.local/contracts/desktop-snapshot.schema.json",
  "type": "object",
  "required": ["generation", "state"],
  "additionalProperties": false,
  "properties": {
    "generation": { "type": "integer", "minimum": 0 },
    "state": { "enum": ["launching", "connected", "restarting", "failed", "stopping"] },
    "connection": {
      "type": "object",
      "required": ["apiUrl", "appToken"],
      "additionalProperties": false,
      "properties": {
        "apiUrl": { "type": "string" },
        "appToken": { "type": "string" }
      }
    },
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" }
      }
    }
  }
}
