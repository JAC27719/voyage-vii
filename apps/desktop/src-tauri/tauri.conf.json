{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voyage VII",
  "version": "0.1.0",
  "identifier": "io.github.jac27719.voyage-vii",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self' ipc: http://tauri.localhost http://localhost:1420; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost; connect-src 'self' ipc: http://tauri.localhost http://localhost:1420 http://127.0.0.1:* http://localhost:*"
    },
    "windows": [
      {
        "label": "main",
        "title": "Voyage VII",
        "width": 1100,
        "height": 720,
        "minWidth": 860,
        "minHeight": 560,
        "resizable": true,
        "visible": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "../icons/32x32.png",
      "../icons/128x128.png",
      "../icons/128x128@2x.png",
      "../icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
