{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://voyage-vii.local/schemas/task-registry.schema.json",
  "title": "Voyage VII delegated task registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "schemaVersion", "project", "tasks"],
  "properties": {
    "$schema": { "const": "./task-registry.schema.json" },
    "schemaVersion": { "const": 1 },
    "project": { "const": "voyage-vii-v2" },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/task" }
    }
  },
  "$defs": {
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "wave",
        "status",
        "inference",
        "dependsOn",
        "ownedPaths",
        "excludedPaths",
        "guide"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Z]+-[0-9]{3}$" },
        "title": { "type": "string", "minLength": 1 },
        "wave": { "type": "integer", "minimum": 0, "maximum": 6 },
        "status": {
          "enum": [
            "blocked",
            "ready",
            "in_progress",
            "submitted",
            "changes_requested",
            "approved",
            "integrated"
          ]
        },
        "inference": { "const": "low" },
        "worker": { "type": ["string", "null"] },
        "reviewer": { "type": ["string", "null"] },
        "dependsOn": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Z]+-[0-9]{3}$" },
          "uniqueItems": true
        },
        "ownedPaths": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "excludedPaths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "guide": { "type": "string", "pattern": "^docs/delivery/tasks/.+\\.md$" },
        "submission": {
          "oneOf": [
            { "type": "null" },
            { "$ref": "#/$defs/submission" }
          ]
        },
        "review": { "type": ["object", "null"] }
      }
    },
    "submission": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base", "revision", "changedPaths", "summary", "acceptanceEvidence"],
      "properties": {
        "base": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "revision": { "type": "string", "minLength": 1 },
        "changedPaths": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "summary": { "type": "string", "minLength": 1 },
        "acceptanceEvidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["criterion", "command", "result"],
            "properties": {
              "criterion": { "type": "string", "minLength": 1 },
              "command": { "type": "string", "minLength": 1 },
              "result": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
