Project voyage_vii_finance_proposal {
  database_type: "SQLite"
  Note: "UNIMPLEMENTED PROPOSAL ONLY. Do not treat this as executable schema. These structures require future reviewed SQLite migrations before they may move into docs/database/sqlite.dbml."
}

Table proposed_accounts {
  id text [pk, not null, note: "Proposed canonical UUIDv7 application identifier."]
  display_name text [not null]
  class text [not null, note: "One of Asset, Liability, Equity, Revenue, Expense, Dividend."]
  tigerbeetle_account_id text [not null, unique, note: "Proposed decimal or canonical text representation of the TigerBeetle u128 identifier."]
  archived_at text [note: "Proposed nullable UTC timestamp."]
}

Table proposed_periods {
  id text [pk, not null]
  state text [not null, note: "Proposed draft, active, closing, or closed state."]
  starts_on text [not null]
  ends_on text [not null]
}
