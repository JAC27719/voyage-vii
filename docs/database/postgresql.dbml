Project voyage_vii_postgresql {
  database_type: "PostgreSQL"
  Note: "SQL migrations are authoritative. This DBML mirrors the implemented schema at API-002."
}

Table schema_migrations {
  version integer [pk, not null, note: "Strictly increasing executable migration version."]
  name text [not null, unique, note: "Stable migration name."]
  sha256 char(64) [not null, note: "CHECK (sha256 ~ '^[0-9a-f]{64}$'); lowercase hexadecimal SHA-256 of the authoritative SQL migration file."]
  applied_at timestamptz [not null, default: `now()`, note: "UTC application timestamp assigned by PostgreSQL."]

  indexes {
    name [unique, name: "schema_migrations_name_key"]
  }
}
