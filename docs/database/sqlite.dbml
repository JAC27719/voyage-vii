Project voyage_vii_sqlite {
  database_type: "SQLite"
  Note: "SQL migrations are authoritative. This DBML mirrors the implemented schema at API-005."
}

Table schema_migrations {
  version integer [pk, not null, note: "Strictly increasing executable migration version."]
  name text [not null, unique, note: "Stable migration name."]
  sha256 text [not null, note: "CHECK (length(sha256) = 64 AND sha256 NOT GLOB '*[^0-9a-f]*'); lowercase hexadecimal SHA-256 of the authoritative SQL migration file."]
  applied_at text [not null, default: `strftime('%Y-%m-%dT%H:%M:%fZ','now')`, note: "UTC application timestamp assigned by SQLite."]

  indexes {
    name [unique, name: "schema_migrations_name_key"]
  }
}
